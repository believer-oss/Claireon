# Normalize line endings: store text as LF in the repo, check out native.
* text=auto

# Source and config -> LF in the repository
*.cpp   text eol=lf
*.h     text eol=lf
*.cs    text eol=lf
*.py    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows PowerShell / batch scripts -> CRLF on checkout
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Unreal binary assets (never normalize / diff)
*.uasset binary
*.umap   binary
*.uplugin text eol=lf
